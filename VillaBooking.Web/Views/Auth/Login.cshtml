@model LoginRequestDTO

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col text-center">
                <p class="section-eyebrow mb-2">Account</p>
                <h1 class="section-heading mb-1">Welcome Back</h1>
                <p class="section-desc mb-0">Sign in to access your villa bookings and manage your account</p>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

                <!-- TempData Messages -->
                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                        <div class="alert-icon-wrap alert-icon-wrap--success me-3">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="flex-grow-1">@TempData["success"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["error"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                        <div class="alert-icon-wrap me-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="flex-grow-1">@TempData["error"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="auth-card">
                    <div class="p-4 p-md-5">

                        <!-- Icon -->
                        <div class="text-center mb-4">
                            <div class="auth-icon-wrap">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                        </div>

                        <!-- Login Form -->
                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly"
                                 class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                            </div>

                            <!-- Email Field -->
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    Email Address
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Password Field -->
                            <div class="mb-4">
                                <label asp-for="Password" class="form-label fw-semibold">
                                    Password
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input asp-for="Password" class="form-control auth-input" placeholder="Enter your password" type="password" />
                                    <button type="button" class="auth-toggle-password" aria-label="Toggle password visibility">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-hero btn-lg d-flex justify-content-center align-items-center gap-2">
                                    Sign In <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>

                            <!-- Divider -->
                            <div class="auth-divider">
                                <span>or</span>
                            </div>

                            <!-- Register Link -->
                            <div class="text-center">
                                <p class="text-muted mb-3">Don't have an account?</p>
                                <a asp-action="Register" class="btn btn-outline-secondary px-4 d-inline-flex align-items-center">
                                    <i class="bi bi-person-plus me-2"></i>Create Account
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(function () {
            $('.auth-toggle-password').on('click', function () {
                var $input = $(this).siblings('input');
                var $icon = $(this).find('i');
                var isPassword = $input.attr('type') === 'password';
                $input.attr('type', isPassword ? 'text' : 'password');
                $icon.toggleClass('bi-eye bi-eye-slash');
            });
        });
    </script>
}

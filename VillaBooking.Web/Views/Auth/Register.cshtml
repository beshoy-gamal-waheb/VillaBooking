@model RegisterationRequestDTO

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col text-center">
                <p class="section-eyebrow mb-2">Account</p>
                <h1 class="section-heading mb-1">Create Account</h1>
                <p class="section-desc mb-0">Join our exclusive villa community and start booking</p>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

                <!-- TempData Messages -->
                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                        <div class="alert-icon-wrap alert-icon-wrap--success me-3">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="flex-grow-1">@TempData["success"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["error"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                        <div class="alert-icon-wrap me-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="flex-grow-1">@TempData["error"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="auth-card">
                    <div class="p-4 p-md-5">

                        <!-- Icon -->
                        <div class="text-center mb-4">
                            <div class="auth-icon-wrap">
                                <i class="bi bi-person-plus"></i>
                            </div>
                        </div>

                        <!-- Register Form -->
                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly"
                                 class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                            </div>

                            <!-- Full Name Field -->
                            <div class="mb-4">
                                <label asp-for="FullName" class="form-label fw-semibold">
                                    Full Name
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    <input asp-for="FullName" class="form-control auth-input" placeholder="Enter your full name" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <!-- Email Field -->
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    Email Address
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Password Field -->
                            <div class="mb-4">
                                <label asp-for="Password" class="form-label fw-semibold">
                                    Password
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input asp-for="Password" class="form-control auth-input" placeholder="Create a password" type="password" />
                                    <button type="button" class="auth-toggle-password" aria-label="Toggle password visibility">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small" style="display:none;"></span>

                                <!-- Password Requirements Checklist -->
                                <ul id="password-rules" class="list-unstyled mt-2 mb-0 small" style="display:none;">
                                    <li id="rule-length" class="d-flex align-items-center gap-2 py-1 text-muted">
                                        <i class="bi bi-x-circle-fill"></i>
                                        <span>At least 6 characters</span>
                                    </li>
                                    <li id="rule-uppercase" class="d-flex align-items-center gap-2 py-1 text-muted">
                                        <i class="bi bi-x-circle-fill"></i>
                                        <span>At least one uppercase letter</span>
                                    </li>
                                    <li id="rule-lowercase" class="d-flex align-items-center gap-2 py-1 text-muted">
                                        <i class="bi bi-x-circle-fill"></i>
                                        <span>At least one lowercase letter</span>
                                    </li>
                                    <li id="rule-digit" class="d-flex align-items-center gap-2 py-1 text-muted">
                                        <i class="bi bi-x-circle-fill"></i>
                                        <span>At least one digit</span>
                                    </li>
                                    <li id="rule-special" class="d-flex align-items-center gap-2 py-1 text-muted">
                                        <i class="bi bi-x-circle-fill"></i>
                                        <span>At least one special character</span>
                                    </li>
                                </ul>
                            </div>

                            <!-- Role Field -->
                            <div class="mb-4">
                                <label asp-for="Role" class="form-label fw-semibold">
                                    Account Type
                                </label>
                                <div class="auth-input-wrap">
                                    <span class="auth-input-icon">
                                        <i class="bi bi-shield-check"></i>
                                    </span>
                                    <select asp-for="Role" class="form-select auth-input">
                                        <option value="Customer" selected>Customer</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                </div>
                                <span asp-validation-for="Role" class="text-danger small"></span>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-hero btn-lg d-flex justify-content-center align-items-center gap-2">
                                    Create Account <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>

                            <!-- Divider -->
                            <div class="auth-divider">
                                <span>or</span>
                            </div>

                            <!-- Login Link -->
                            <div class="text-center">
                                <p class="text-muted mb-3">Already have an account?</p>
                                <a asp-action="Login" class="btn btn-outline-secondary px-4 d-inline-flex align-items-center">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In Instead
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
                $(function () {

            var $form = $('form');
            var $password = $('#Password');
            var $rulesList = $('#password-rules');

            // show validation on blur
            $form.find('input').on('blur', function () {
                $(this).valid();
            });

            var rules = [
                { id: '#rule-length',    test: v => v.length >= 6 },
                { id: '#rule-uppercase', test: v => /[A-Z]/.test(v) },
                { id: '#rule-lowercase', test: v => /[a-z]/.test(v) },
                { id: '#rule-digit',     test: v => /\d/.test(v) },
                { id: '#rule-special',   test: v => /[\W_]/.test(v) }
            ];

            $form.on('submit', function (e) {

                if (!$form.valid()) {
                    return;
                }

                var value = $password.val();
                var allPassed = rules.every(rule => rule.test(value));

                if (!allPassed) {
                    e.preventDefault();
                    $rulesList.slideDown(200);

                    rules.forEach(rule => {
                        var $li = $(rule.id);
                        if (!rule.test(value)) {
                            $li.removeClass('text-muted text-success').addClass('text-danger');
                        }
                    });
                }
            });

            $password.on('input focus', function () {

                var value = $password.val();

                if (value.length > 0) {
                    $rulesList.slideDown(200);
                } else {
                    $rulesList.slideUp(200);
                }

                rules.forEach(rule => {
                    var $li = $(rule.id);
                    var $icon = $li.find('i');

                    if (rule.test(value)) {
                        $li.removeClass('text-muted text-danger').addClass('text-success');
                        $icon.removeClass('bi-x-circle-fill').addClass('bi-check-circle-fill');
                    } else {
                        $li.removeClass('text-success').addClass('text-muted');
                        $icon.removeClass('bi-check-circle-fill').addClass('bi-x-circle-fill');
                    }
                });
            });

            $('.auth-toggle-password').on('click', function () {
                var $input = $(this).siblings('input');
                var $icon = $(this).find('i');

                var isPassword = $input.attr('type') === 'password';
                $input.attr('type', isPassword ? 'text' : 'password');

                $icon.toggleClass('bi-eye bi-eye-slash');
            });

        });
    </script>
}

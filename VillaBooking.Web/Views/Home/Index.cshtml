@model VillaListViewModel

<!-- Hero Section -->
<section class="hero-section">
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-indicators hero-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="hero-panel" style="background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 50%, #0ea5e9 100%);">
                    <div class="hero-overlay"></div>
                    <div class="container position-relative">
                        <div class="row min-vh-hero align-items-center">
                            <div class="col-lg-7">
                                <div class="hero-badge">
                                    <i class="bi bi-stars me-1"></i> Premium Collection
                                </div>
                                <h1 class="hero-heading">Find Your Perfect <br><span class="hero-heading-accent">Luxury Villa</span></h1>
                                <p class="hero-text">Discover handpicked villas with world-class amenities, breathtaking views, and unmatched comfort for your dream getaway.</p>
                                <a href="#villa-listings" class="btn btn-hero">
                                    Explore Villas <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="hero-panel" style="background: linear-gradient(160deg, #1a1a2e 0%, #4a1942 50%, #c850c0 100%);">
                    <div class="hero-overlay"></div>
                    <div class="container position-relative">
                        <div class="row min-vh-hero align-items-center">
                            <div class="col-lg-7">
                                <div class="hero-badge">
                                    <i class="bi bi-gem me-1"></i> World-Class Living
                                </div>
                                <h1 class="hero-heading">Experience <br><span class="hero-heading-accent">Premium Amenities</span></h1>
                                <p class="hero-text">Every villa features curated amenities — private pools, chef kitchens, spa facilities, and concierge services.</p>
                                <a href="#villa-listings" class="btn btn-hero">
                                    View Collection <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="hero-panel" style="background: linear-gradient(160deg, #0a0f1a 0%, #1b4332 50%, #40916c 100%);">
                    <div class="hero-overlay"></div>
                    <div class="container position-relative">
                        <div class="row min-vh-hero align-items-center">
                            <div class="col-lg-7">
                                <div class="hero-badge">
                                    <i class="bi bi-calendar-check me-1"></i> Book Today
                                </div>
                                <h1 class="hero-heading">Create Memories <br><span class="hero-heading-accent">That Last Forever</span></h1>
                                <p class="hero-text">From serene beachfront retreats to mountain hideaways — your unforgettable escape starts here.</p>
                                <a href="#villa-listings" class="btn btn-hero">
                                    Check Availability <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev hero-nav" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="hero-nav-icon"><i class="bi bi-chevron-left"></i></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next hero-nav" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="hero-nav-icon"><i class="bi bi-chevron-right"></i></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</section>

<!-- Listings Section -->
<section class="listings-section" id="villa-listings">
    <div class="container">

        <!-- Section Heading -->
        <div class="row justify-content-center mb-5">
            <div class="col-lg-7 text-center">
                <p class="section-eyebrow">Our Properties</p>
                <h2 class="section-heading">Handpicked Luxury Villas</h2>
                <p class="section-desc">Explore a curated collection of premium villas — each designed to deliver comfort, elegance, and an unforgettable experience.</p>
            </div>
        </div>

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger auto-hide d-flex align-items-center rounded-3 border-0 shadow-sm mb-5" role="alert">
                <div class="alert-icon-wrap me-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="flex-grow-1">@TempData["error"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Filter & Sort Panel -->
        <div class="qc-panel mb-4">
            <button class="btn qc-toggle-btn w-100 d-flex align-items-center justify-content-between"
                    type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel" aria-expanded="false">
                <span><i class="bi bi-funnel me-2"></i>Filter & Sort Villas</span>
                <i class="bi bi-chevron-down qc-chevron"></i>
            </button>
            <div class="collapse" id="filterPanel">
                <form id="filterForm" method="get" class="qc-form">
                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-md-6 col-lg-4">
                            <label class="qc-label" for="qcName">Name</label>
                            <input type="text" class="form-control qc-input" id="qcName"
                                   name="Name" value="@Model.Query.Name" placeholder="Search by name..." />
                        </div>
                        <!-- Details -->
                        <div class="col-md-6 col-lg-4">
                            <label class="qc-label" for="qcDetails">Details</label>
                            <input type="text" class="form-control qc-input" id="qcDetails"
                                   name="Details" value="@Model.Query.Details" placeholder="Search in details..." />
                        </div>
                        <!-- Sort By -->
                        <div class="col-md-6 col-lg-4">
                            <label class="qc-label" for="qcSortBy">Sort By</label>
                            <div class="d-flex gap-2">
                                <select class="form-select qc-input" id="qcSortBy" name="SortBy">
                                    <option value="">Default</option>
                                    <option value="name" selected="@(Model.Query.SortBy == "name")">Name</option>
                                    <option value="rate" selected="@(Model.Query.SortBy == "rate")">Rate</option>
                                    <option value="occupancy" selected="@(Model.Query.SortBy == "occupancy")">Occupancy</option>
                                    <option value="sqft" selected="@(Model.Query.SortBy == "sqft")">Sqft</option>
                                </select>
                                <select class="form-select qc-input" id="qcSortOrder" name="SortOrder" style="max-width: 130px;">
                                    <option value="asc" selected="@(Model.Query.SortOrder == "asc")">Asc</option>
                                    <option value="desc" selected="@(Model.Query.SortOrder == "desc")">Desc</option>
                                </select>
                            </div>
                        </div>
                        <!-- Min/Max Occupancy -->
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMinOcc">Min Occupancy</label>
                            <input type="number" class="form-control qc-input" id="qcMinOcc"
                                   name="MinOccupancy" value="@Model.Query.MinOccupancy" min="0" placeholder="Min" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMaxOcc">Max Occupancy</label>
                            <input type="number" class="form-control qc-input" id="qcMaxOcc"
                                   name="MaxOccupancy" value="@Model.Query.MaxOccupancy" min="0" placeholder="Max" />
                        </div>
                        <!-- Min/Max Rate -->
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMinRate">Min Rate ($)</label>
                            <input type="number" class="form-control qc-input" id="qcMinRate"
                                   name="MinRate" value="@Model.Query.MinRate" min="0" step="0.01" placeholder="Min" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMaxRate">Max Rate ($)</label>
                            <input type="number" class="form-control qc-input" id="qcMaxRate"
                                   name="MaxRate" value="@Model.Query.MaxRate" min="0" step="0.01" placeholder="Max" />
                        </div>
                        <!-- Min/Max Sqft -->
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMinSqft">Min Sqft</label>
                            <input type="number" class="form-control qc-input" id="qcMinSqft"
                                   name="MinSqft" value="@Model.Query.MinSqft" min="0" placeholder="Min" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcMaxSqft">Max Sqft</label>
                            <input type="number" class="form-control qc-input" id="qcMaxSqft"
                                   name="MaxSqft" value="@Model.Query.MaxSqft" min="0" placeholder="Max" />
                        </div>
                        <!-- Page Size -->
                        <div class="col-6 col-md-3">
                            <label class="qc-label" for="qcPageSize">Per Page</label>
                            <select class="form-select qc-input" id="qcPageSize" name="PageSize">
                                <option value="6" selected="@(Model.Query.PageSize == 6)">6</option>
                                <option value="9" selected="@(Model.Query.PageSize == 9)">9</option>
                                <option value="12" selected="@(Model.Query.PageSize == 12)">12</option>
                                <option value="24" selected="@(Model.Query.PageSize == 24)">24</option>
                            </select>
                        </div>
                        <!-- Actions -->
                        <div class="col-md-3 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-hero flex-grow-1">
                                <i class="bi bi-search me-1"></i> Search
                            </button>
                            <a href="#" id="clearFiltersBtn" class="btn qc-btn-reset">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        </div>
                    </div>
                    <input type="hidden" id="hiddenPage" name="Page" value="1" />
                </form>
            </div>
        </div>

        <div id="villasContainer">
            @await Html.PartialAsync("_HomeVillasGrid", Model)
        </div>

    </div>
</section>

@section Scripts {
    <style>
        .ajax-loading-overlay {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 4rem 1rem;
            color: var(--text-secondary, #6c757d);
        }
        .ajax-loading-overlay .spinner-border {
            width: 2.5rem;
            height: 2.5rem;
            border-width: 3px;
            color: var(--hero-start, #6366f1);
        }
    </style>
    <script>
        $(function () {
            var $form = $('#filterForm');
            var $container = $('#villasContainer');
            var ajaxUrl = '@Url.Action("GetVillasAjax", "Home")';

            // ---------- helpers ----------
            function showLoading() {
                $container.html(
                    '<div class="ajax-loading-overlay">' +
                        '<div class="spinner-border" role="status"><span class="visually-hidden">Loading…</span></div>' +
                        '<span>Loading villas…</span>' +
                    '</div>'
                );
            }

            function loadVillas(page) {
                $('#hiddenPage').val(page || 1);
                var queryString = $form.serialize();
                showLoading();

                $.get(ajaxUrl + '?' + queryString)
                    .done(function (html) {
                        $container.html(html);
                    })
                    .fail(function () {
                        $container.html(
                            '<div class="text-center text-danger py-5">' +
                                '<i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i>' +
                                'Failed to load villas. Please try again.' +
                            '</div>'
                        );
                    });
            }

            // ---------- form submit ----------
            $form.on('submit', function (e) {
                e.preventDefault();
                loadVillas(1);
            });

            // ---------- sort / pageSize change ----------
            $('#qcSortBy, #qcSortOrder, #qcPageSize').on('change', function () {
                loadVillas(1);
            });

            // ---------- pagination ----------
            $container.on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var $li = $(this).closest('li');
                if ($li.hasClass('disabled') || $li.hasClass('active')) return;
                var page = $(this).data('page');
                if (page) loadVillas(page);
            });

            // ---------- clear filters ----------
            $('#clearFiltersBtn').on('click', function (e) {
                e.preventDefault();
                $form[0].reset();
                $form.find('select[name="PageSize"]').val('6');
                loadVillas(1);
            });

            // ---------- "Clear Filters" inside empty-state partial ----------
            $container.on('click', '.ajax-clear-filters', function (e) {
                e.preventDefault();
                $form[0].reset();
                $form.find('select[name="PageSize"]').val('6');
                loadVillas(1);
            });
        });
    </script>
}

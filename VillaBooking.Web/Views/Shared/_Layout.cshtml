<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Villa Booking</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/VillaBooking.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg fixed-top site-navbar">
            <div class="container">
                <a class="navbar-brand site-logo" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-building me-2"></i>Villa<span class="logo-accent">Booking</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="navbar-collapse collapse justify-content-end">
                    <ul class="navbar-nav align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Villa" asp-action="Index">
                                <i class="bi bi-house-gear me-1"></i>Villa Management
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer text-center text-md-start">
        <div class="container">
            <div class="row align-items-center gy-4">
                <div class="col-lg-4 text-center text-lg-start">
                    <div class="footer-brand">
                        <i class="bi bi-building me-2"></i>Villa<span class="logo-accent">Booking</span>
                    </div>
                    <p class="footer-tagline">Premium luxury villas for unforgettable getaways.</p>
                </div>
                <div class="col-lg-4 text-center">
                    <ul class="footer-links d-flex justify-content-center gap-3 list-unstyled mb-0">
                        <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Villa" asp-action="Index">Villas</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 text-center text-lg-end">
                    <p class="footer-copy">&copy; 2026 Villa Booking. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

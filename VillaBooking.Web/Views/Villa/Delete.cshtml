@model VillaDTO

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <p class="section-eyebrow mb-2">Villa Management</p>
                <h1 class="section-heading mb-1">Delete Villa</h1>
                <p class="section-desc mb-0">Review the villa details below before confirming deletion</p>
            </div>
            <div class="col-auto">
                <a asp-controller="Villa" asp-action="Index" class="btn btn-hero">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <!-- Warning -->
                <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                    <div class="alert-icon-wrap me-3">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <strong>This action is irreversible.</strong> Once deleted, this villa and all associated data will be permanently removed.
                    </div>
                </div>

                <div class="villa-table-card">
                    <div class="p-4 p-md-5">

                        <!-- Villa Image -->
                        <div class="text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="@Model.Name"
                                     class="rounded-3 shadow-sm"
                                     style="max-height: 240px; width: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="v-card-img-empty rounded-3" style="height: 200px;">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                        </div>

                        <!-- Villa Details -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Villa Name</label>
                            <input type="text" class="form-control" value="@Model.Name" disabled />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" disabled>@Model.Details</textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-semibold">Nightly Rate</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="text" class="form-control" value="@Model.Rate.ToString("N2")" disabled />
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-semibold">Max Occupancy</label>
                                <input type="text" class="form-control" value="@Model.Occupancy" disabled />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Square Feet</label>
                            <input type="text" class="form-control" value="@Model.Sqft.ToString("N0")" disabled />
                        </div>

                        <!-- Action Buttons -->
                        <form method="post" asp-controller="Villa" asp-action="Delete" asp-route-id="@Model.Id">
                            <div class="d-flex gap-3 pt-2 justify-content-center justify-content-lg-end flex-wrap">
                                <a asp-controller="Villa" asp-action="Index" class="btn btn-outline-secondary px-4 d-inline-flex align-items-center">
                                    Cancel
                                </a>
                                <button type="submit" class="btn btn-danger px-4 d-inline-flex align-items-center">
                                    <i class="bi bi-trash3 me-2"></i>Delete Villa
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

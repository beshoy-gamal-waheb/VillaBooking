@model VillaDTO

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <p class="section-eyebrow mb-2">Our Properties</p>
                <h1 class="section-heading mb-1">@Model.Name</h1>
                <p class="section-desc mb-0">Browse villa details and get in touch to make a booking</p>
            </div>
            <div class="col-auto">
                <a asp-controller="Home" asp-action="Index" class="btn btn-hero">
                    <i class="bi bi-arrow-left me-2"></i>Back to Listings
                </a>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <div class="villa-table-card">

                    <!-- Villa Image -->
                    <div class="v-card-media" style="height: 380px;">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="v-card-img" alt="@Model.Name">
                        }
                        else
                        {
                            <div class="v-card-img-empty">
                                <i class="bi bi-image"></i>
                            </div>
                        }
                        <div class="v-card-price">
                            $@Model.Rate.ToString("N0")<span class="v-card-price-unit">/night</span>
                        </div>
                    </div>

                    <div class="p-4 p-md-5">

                        <!-- Villa Name -->
                        <h2 class="v-card-name mb-3" style="font-size: 1.75rem;">@Model.Name</h2>

                        <!-- Description -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">About this Villa</label>
                            <p class="v-card-detail" style="-webkit-line-clamp: unset; overflow: visible;">@Model.Details</p>
                        </div>

                        <!-- Stats strip (mini) -->
                        <div class="stats-strip mb-4">
                            <div class="row g-3 align-items-stretch">

                                <div class="col-6 col-md-6">
                                    <div class="s-stat">
                                        <div class="s-stat-icon s-stat-icon--violet">
                                            <i class="bi bi-people-fill"></i>
                                        </div>
                                        <div class="s-stat-body">
                                            <span class="s-stat-num">@Model.Occupancy</span>
                                            <span class="s-stat-label">Max Guests</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-6 col-md-6">
                                    <div class="s-stat">
                                        <div class="s-stat-icon s-stat-icon--amber">
                                            <i class="bi bi-arrows-fullscreen"></i>
                                        </div>
                                        <div class="s-stat-body">
                                            <span class="s-stat-num">@Model.Sqft.ToString("N0")</span>
                                            <span class="s-stat-label">Square Feet</span>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Contact Button -->
                        <div class="d-grid">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a href="mailto:beshoygamall12@gmail.com"
                                   class="btn btn-contact-villa"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-envelope me-2"></i>Contact Us

                                </a>
                            }
                            else
                            {
                                <a asp-controller="Auth"
                                   asp-action="Login"
                                   class="btn btn-contact-villa"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-envelope me-2"></i>Contact Us

                                </a>
                            }
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

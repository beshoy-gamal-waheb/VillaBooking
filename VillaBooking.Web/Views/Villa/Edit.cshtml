@model VillaUpsertDTO

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <p class="section-eyebrow mb-2">Villa Management</p>
                <h1 class="section-heading mb-1">Edit Villa</h1>
                <p class="section-desc mb-0">Update the villa details below</p>
            </div>
            <div class="col-auto">
                <a asp-controller="Villa" asp-action="Index" class="btn btn-hero">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="villa-table-card">
                    <div class="p-4 p-md-5">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                        </div>

                        <form method="post" asp-controller="Villa" asp-action="Edit" asp-route-id="@Context.Request.RouteValues["id"]">

                            <!-- Villa Name -->
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-semibold">
                                    Villa Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="Enter villa name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <!-- Details -->
                            <div class="mb-4">
                                <label asp-for="Details" class="form-label fw-semibold">Description</label>
                                <textarea asp-for="Details" class="form-control" rows="4"
                                          placeholder="Describe the villa"></textarea>
                                <span asp-validation-for="Details" class="text-danger small"></span>
                            </div>

                            <!-- Rate and Occupancy -->
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label asp-for="Rate" class="form-label fw-semibold">
                                        Nightly Rate <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="Rate" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Rate" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="Occupancy" class="form-label fw-semibold">
                                        Max Occupancy <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Occupancy" type="number" class="form-control" placeholder="Number of guests" />
                                    <span asp-validation-for="Occupancy" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Sqft -->
                            <div class="mb-4">
                                <label asp-for="Sqft" class="form-label fw-semibold">
                                    Square Feet <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Sqft" type="number" class="form-control" placeholder="Area in sqft" />
                                <span asp-validation-for="Sqft" class="text-danger small"></span>
                            </div>

                            <!-- Image URL -->
                            <div class="mb-4">
                                <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label>
                                <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-flex gap-3 pt-2 justify-content-center justify-content-lg-end flex-wrap">
                                <a asp-controller="Villa" asp-action="Index" class="btn btn-outline-secondary px-4 d-inline-flex align-items-center">
                                    Cancel
                                </a>
                                <button type="submit" class="btn btn-hero">
                                    <i class="bi bi-check-lg me-2"></i>Update Villa
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

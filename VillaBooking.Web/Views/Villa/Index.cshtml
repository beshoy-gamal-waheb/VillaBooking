@model IEnumerable<VillaDTO>

<!-- Page Header -->
<section class="villa-mgmt-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <p class="section-eyebrow mb-2">Dashboard</p>
                <h1 class="section-heading mb-1">Villa Management</h1>
                <p class="section-desc mb-0">Create, edit, and manage your villa listings</p>
            </div>
            <div class="col-auto">
                <a asp-controller="Villa" asp-action="Create" class="btn btn-hero">
                    <i class="bi bi-plus-lg me-2"></i>Add New Villa
                </a>
            </div>
        </div>
    </div>
</section>

<section class="villa-mgmt-content">
    <div class="container">

        <!-- Messages -->
        @if (TempData["success"] != null)
        {
            <div class="alert alert-success auto-hide d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                <div class="alert-icon-wrap alert-icon-wrap--success me-3">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="flex-grow-1">@TempData["success"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger auto-hide d-flex align-items-center rounded-3 border-0 shadow-sm mb-4" role="alert">
                <div class="alert-icon-wrap me-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="flex-grow-1">@TempData["error"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="row justify-content-center">
                <div class="col-lg-5">
                    <div class="empty-state-card text-center">
                        <div class="empty-icon-wrap">
                            <i class="bi bi-house-slash"></i>
                        </div>
                        <h4 class="mt-4 mb-2">No Villas Available</h4>
                        <p class="text-muted mb-4">Get started by creating your first villa.</p>
                        <a href="#" class="btn btn-hero">
                            <i class="bi bi-plus-lg me-2"></i>Create Villa
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Villa Table -->
            <div class="villa-table-card">
                <div class="table-responsive">
                    <table class="table villa-table mb-0">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Details</th>
                                <th>Rate</th>
                                <th>Occupancy</th>
                                <th>Sqft</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var villa in Model)
                            {
                                <tr>
                                    <td class="align-middle">
                                        @if(!string.IsNullOrEmpty(villa.ImageUrl))
                                        {
                                            <img src="@villa.ImageUrl" class="villa-table-thumb" alt="@villa.Name">
                                        }
                                        else
                                        {
                                            <div class="villa-table-thumb-empty">
                                                <i class="bi bi-image"></i>
                                            </div>
                                        }

                                    </td>
                                    <td class="align-middle">
                                        <span class="villa-table-name">@villa.Name</span>
                                    </td>
                                    <td class="align-middle">
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(villa.Details))
                                            {
                                                @(villa.Details.Length > 50 ? villa.Details.Substring(0, 50) + "..." : villa.Details)
                                            }
                                            else
                                            {
                                                <span class="fst-italic">No details</span>
                                            }
                                        </small>
                                    </td>
                                    <td class="align-middle">
                                        <span class="villa-table-rate">$@villa.Rate.ToString("N0")</span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="v-meta-item">
                                            <i class="bi bi-people-fill"></i> @villa.Occupancy
                                        </span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="v-meta-item">
                                            <i class="bi bi-aspect-ratio"></i> @villa.Sqft.ToString("N0")
                                        </span>
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="villa-table-actions">
                                            <a asp-action="Edit" asp-route-id="@villa.Id"
                                               class="villa-action-btn villa-action-btn--edit" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@villa.Id"
                                               class="villa-action-btn villa-action-btn--delete" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Summary -->
            <div class="stats-strip">
                <div class="row g-4 align-items-stretch">
                    <div class="col-6 col-lg-3">
                        <div class="s-stat">
                            <div class="s-stat-icon s-stat-icon--blue">
                                <i class="bi bi-building"></i>
                            </div>
                            <div class="s-stat-body">
                                <span class="s-stat-num">@Model?.Count()</span>
                                <span class="s-stat-label">Total Villas</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="s-stat">
                            <div class="s-stat-icon s-stat-icon--green">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                            <div class="s-stat-body">
                                <span class="s-stat-num">$@Model.Min(v => v.Rate).ToString("N0")</span>
                                <span class="s-stat-label">Starting From</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="s-stat">
                            <div class="s-stat-icon s-stat-icon--violet">
                                <i class="bi bi-people-fill"></i>
                            </div>
                            <div class="s-stat-body">
                                <span class="s-stat-num">@Model.Max(v => v.Occupancy)</span>
                                <span class="s-stat-label">Max Guests</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="s-stat">
                            <div class="s-stat-icon s-stat-icon--amber">
                                <i class="bi bi-arrows-fullscreen"></i>
                            </div>
                            <div class="s-stat-body">
                                <span class="s-stat-num">@Model.Sum(v => v.Sqft).ToString("N0")</span>
                                <span class="s-stat-label">Total Sqft</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
